@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Regulation Library";
}
<style>[x-cloak]{display:none!important}</style>

<div x-data="{
    view: 'table',
    search: '',
    body: '',
    priority: '',
    regs: [
        { id:1, title:'GST Rate Change on Textile Products', body:'CBIC', priority:'High', date:'15 Mar 2024', tags:['GST','Textile'], summary:'Revised GST rates on synthetic textile products from 5% to 12%.' },
        { id:2, title:'PF Contribution Threshold Revised', body:'EPFO', priority:'High', date:'10 Mar 2024', tags:['PF','Labour'], summary:'Mandatory PF salary threshold raised to ₹21,000/month.' },
        { id:3, title:'SEBI LODR Amendment — Board Composition', body:'SEBI', priority:'Medium', date:'5 Mar 2024', tags:['SEBI','Governance'], summary:'At least one independent woman director required by 31 March.' },
        { id:4, title:'FSSAI Labelling Rules for Packaged Food', body:'FSSAI', priority:'Medium', date:'1 Mar 2024', tags:['FSSAI','Food'], summary:'Mandatory front-of-pack nutritional labelling for packaged food.' },
        { id:5, title:'RBI Digital Lending Guidelines Update', body:'RBI', priority:'High', date:'25 Feb 2024', tags:['RBI','Fintech'], summary:'Updated KYC and disbursement norms for digital lenders.' },
        { id:6, title:'MCA E-Form AOC-4 Deadline Extension', body:'MCA', priority:'Low', date:'20 Feb 2024', tags:['MCA','Filing'], summary:'AOC-4 deadline extended to 31 March 2025.' },
        { id:7, title:'IRDAI Health Insurance Standardisation', body:'IRDAI', priority:'Medium', date:'15 Feb 2024', tags:['IRDAI','Insurance'], summary:'Standard definitions for pre-existing conditions in health policies.' },
        { id:8, title:'TRAI OTT Regulation Framework', body:'TRAI', priority:'Low', date:'10 Feb 2024', tags:['TRAI','Telecom'], summary:'Consultation paper on over-the-top communication services regulation.' },
    ],
    get filtered() {
        return this.regs.filter(r => {
            const ms = !this.search || r.title.toLowerCase().includes(this.search.toLowerCase()) || r.body.toLowerCase().includes(this.search.toLowerCase());
            const mb = !this.body || r.body === this.body;
            const mp = !this.priority || r.priority === this.priority;
            return ms && mb && mp;
        });
    }
}" class="space-y-5">

    <!-- Header -->
    <div class="flex items-center justify-between flex-wrap gap-3">
        <div>
            <h1 class="text-2xl font-black text-gray-900">Regulation Library</h1>
            <p class="text-gray-500 text-sm mt-1">Browse all monitored regulations relevant to your business</p>
        </div>
        <div class="flex items-center gap-2 bg-gray-100 p-1 rounded-xl">
            <button @@click="view='table'" :class="view==='table' ? 'bg-white shadow' : 'text-gray-400'"
                    class="p-2 rounded-lg transition-all"><i data-lucide="list" class="w-4 h-4"></i></button>
            <button @@click="view='grid'" :class="view==='grid' ? 'bg-white shadow' : 'text-gray-400'"
                    class="p-2 rounded-lg transition-all"><i data-lucide="grid-3x3" class="w-4 h-4"></i></button>
        </div>
    </div>

    <!-- Search + filters -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-4 flex flex-col sm:flex-row gap-3 items-start sm:items-center">
        <div class="relative flex-1 w-full">
            <i data-lucide="search" class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none"></i>
            <input type="text" placeholder="Search by title, body…" x-model="search"
                   class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-200 focus:ring-2 focus:ring-brand-400 outline-none text-sm" />
        </div>
        <select x-model="body" class="px-3 py-2.5 border border-gray-200 rounded-xl text-sm bg-white focus:ring-2 focus:ring-brand-400 outline-none">
            <option value="">All Bodies</option>
            @foreach (var b in new[] { "CBIC","EPFO","SEBI","FSSAI","RBI","MCA","IRDAI","TRAI" })
            {<option value="@b">@b</option>}
        </select>
        <select x-model="priority" class="px-3 py-2.5 border border-gray-200 rounded-xl text-sm bg-white focus:ring-2 focus:ring-brand-400 outline-none">
            <option value="">All Priorities</option>
            <option>High</option><option>Medium</option><option>Low</option>
        </select>
    </div>

    <!-- Table view -->
    <div x-show="view==='table'" class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-100">
                <tr>
                    <th class="text-left px-6 py-3.5 text-xs font-semibold text-gray-500 uppercase tracking-wider">Regulation</th>
                    <th class="text-left px-4 py-3.5 text-xs font-semibold text-gray-500 uppercase tracking-wider hidden md:table-cell">Body</th>
                    <th class="text-left px-4 py-3.5 text-xs font-semibold text-gray-500 uppercase tracking-wider hidden lg:table-cell">Priority</th>
                    <th class="text-left px-4 py-3.5 text-xs font-semibold text-gray-500 uppercase tracking-wider hidden lg:table-cell">Date</th>
                    <th class="px-4 py-3.5"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                <template x-for="r in filtered" :key="r.id">
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-6 py-4">
                            <p class="font-semibold text-gray-900 leading-tight" x-text="r.title"></p>
                            <p class="text-xs text-gray-400 mt-0.5 line-clamp-1" x-text="r.summary"></p>
                        </td>
                        <td class="px-4 py-4 hidden md:table-cell">
                            <span class="text-xs font-semibold bg-gray-100 text-gray-700 px-2 py-1 rounded-lg" x-text="r.body"></span>
                        </td>
                        <td class="px-4 py-4 hidden lg:table-cell">
                            <span :class="{ 'bg-red-100 text-red-700': r.priority==='High', 'bg-amber-100 text-amber-700': r.priority==='Medium', 'bg-gray-100 text-gray-600': r.priority==='Low' }"
                                  class="text-xs font-semibold px-2 py-0.5 rounded-full" x-text="r.priority"></span>
                        </td>
                        <td class="px-4 py-4 text-xs text-gray-400 hidden lg:table-cell" x-text="r.date"></td>
                        <td class="px-4 py-4">
                            <a :href="'/Alerts/Detail/' + r.id"
                               class="flex items-center gap-1 text-xs text-brand-600 hover:text-brand-700 font-medium whitespace-nowrap">
                                View <i data-lucide="arrow-right" class="w-3 h-3"></i>
                            </a>
                        </td>
                    </tr>
                </template>
                <template x-if="filtered.length === 0">
                    <tr><td colspan="5" class="text-center py-16 text-gray-400">No regulations match your filters</td></tr>
                </template>
            </tbody>
        </table>
    </div>

    <!-- Grid view -->
    <div x-show="view==='grid'" x-cloak class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
        <template x-for="r in filtered" :key="r.id">
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 hover:shadow-md transition-shadow">
                <div class="flex items-start justify-between gap-2 mb-3">
                    <span :class="{ 'bg-red-100 text-red-700': r.priority==='High', 'bg-amber-100 text-amber-700': r.priority==='Medium', 'bg-gray-100 text-gray-600': r.priority==='Low' }"
                          class="text-xs font-semibold px-2 py-0.5 rounded-full" x-text="r.priority"></span>
                    <span class="text-xs text-gray-400" x-text="r.date"></span>
                </div>
                <h3 class="font-bold text-gray-900 text-sm leading-tight mb-2" x-text="r.title"></h3>
                <p class="text-xs text-gray-500 line-clamp-2 mb-3" x-text="r.summary"></p>
                <div class="flex items-center justify-between pt-3 border-t border-gray-100">
                    <span class="text-xs font-semibold bg-gray-100 text-gray-600 px-2 py-1 rounded-lg" x-text="r.body"></span>
                    <a :href="'/Alerts/Detail/' + r.id" class="text-xs text-brand-600 font-medium hover:text-brand-700">Read more →</a>
                </div>
            </div>
        </template>
    </div>
</div>
