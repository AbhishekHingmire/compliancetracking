@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Alert Detail";
}
<style>[x-cloak]{display:none!important}</style>

<div x-data="{ langHindi: false, actionsDone: [false, false, false] }">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-gray-400 mb-6">
        <a asp-controller="Dashboard" asp-action="Index" class="hover:text-brand-600 transition-colors">Dashboard</a>
        <i data-lucide="chevron-right" class="w-4 h-4"></i>
        <a asp-controller="Alerts" asp-action="Index" class="hover:text-brand-600 transition-colors">Alerts</a>
        <i data-lucide="chevron-right" class="w-4 h-4"></i>
        <span class="text-gray-700 font-medium">GST Rate Change on Textile Products</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Main content -->
        <div class="lg:col-span-2 space-y-5">
            <!-- Header card -->
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
                <div class="flex items-start justify-between gap-3 mb-4">
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 mb-2">
                            <span class="text-xs font-semibold bg-red-100 text-red-700 px-2.5 py-1 rounded-full">High Priority</span>
                            <span class="text-xs font-semibold bg-orange-100 text-orange-700 px-2.5 py-1 rounded-full">Unread</span>
                        </div>
                        <h1 class="text-2xl font-black text-gray-900 leading-tight">GST Rate Change on Textile Products</h1>
                        <div class="flex flex-wrap items-center gap-3 mt-3 text-sm text-gray-500">
                            <span class="flex items-center gap-1.5"><i data-lucide="building-2" class="w-4 h-4"></i>CBIC</span>
                            <span class="flex items-center gap-1.5"><i data-lucide="hash" class="w-4 h-4"></i>Notification No. 01/2024-CT(Rate)</span>
                            <span class="flex items-center gap-1.5"><i data-lucide="calendar" class="w-4 h-4"></i>Published 15 Mar 2024</span>
                            <span class="flex items-center gap-1.5"><i data-lucide="clock" class="w-4 h-4"></i>Effective 1 Apr 2024</span>
                        </div>
                    </div>
                    <div class="flex flex-col gap-2 flex-shrink-0">
                        <a href="#" class="flex items-center gap-1.5 text-xs font-medium text-brand-600 hover:text-brand-700 bg-brand-50 px-3 py-2 rounded-xl">
                            <i data-lucide="external-link" class="w-3.5 h-3.5"></i>Original Doc
                        </a>
                        <a href="#" class="flex items-center gap-1.5 text-xs font-medium text-gray-600 hover:text-gray-700 bg-gray-100 px-3 py-2 rounded-xl">
                            <i data-lucide="file-down" class="w-3.5 h-3.5"></i>Download PDF
                        </a>
                    </div>
                </div>
                <!-- Tags -->
                <div class="flex flex-wrap gap-2 pt-4 border-t border-gray-100">
                    @foreach (var t in new[] { "GST", "Textile", "CBIC", "Rate Change", "Manufacturing" })
                    {<span class="text-xs bg-gray-100 text-gray-600 font-medium px-3 py-1 rounded-full">@t</span>}
                </div>
            </div>

            <!-- Summary card with language toggle -->
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
                <div class="flex items-center justify-between mb-4">
                    <h2 class="font-bold text-gray-900">AI Summary</h2>
                    <div class="flex items-center gap-2 bg-gray-100 rounded-xl p-1">
                        <button @@click="langHindi=false" :class="!langHindi ? 'bg-white shadow text-brand-700' : 'text-gray-500'"
                                class="px-3 py-1.5 text-xs font-semibold rounded-lg transition-all">English</button>
                        <button @@click="langHindi=true" :class="langHindi ? 'bg-white shadow text-brand-700' : 'text-gray-500'"
                                class="px-3 py-1.5 text-xs font-semibold rounded-lg transition-all">हिंदी</button>
                    </div>
                </div>
                <p x-show="!langHindi" class="text-gray-700 leading-relaxed text-sm">
                    The Central Board of Indirect Taxes and Customs (CBIC) has revised GST rates on synthetic textile products from 5% to 12% effective 1 April 2024. This affects manufacturers, traders, and importers dealing in synthetic fibres, yarns, and fabrics. Businesses must update their billing software, invoicing templates, and revise pricing contracts with customers before the effective date.
                </p>
                <p x-show="langHindi" x-cloak class="text-gray-700 leading-relaxed text-sm" lang="hi">
                    केंद्रीय अप्रत्यक्ष कर और सीमा शुल्क बोर्ड (CBIC) ने 1 अप्रैल 2024 से सिंथेटिक वस्त्र उत्पादों पर GST दरें 5% से बढ़ाकर 12% कर दी हैं। इससे सिंथेटिक रेशे, धागे और कपड़ों के निर्माताओं, व्यापारियों और आयातकों पर असर पड़ेगा। व्यवसायों को प्रभावी तिथि से पहले अपने बिलिंग सॉफ़्टवेयर, इनवॉइस टेम्पलेट अपडेट करने और ग्राहकों के साथ मूल्य अनुबंध संशोधित करने होंगे।
                </p>
            </div>

            <!-- Action checklist -->
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
                <h2 class="font-bold text-gray-900 mb-4">Action Checklist</h2>
                <div class="space-y-3">
                    @{
                        var actions = new[] {
                            "Update GST rates in your billing and accounting software (Tally/Zoho/QuickBooks) from 5% to 12% for HS Code 5402–5408.",
                            "Review and revise all active customer contracts and purchase orders that reference the 5% GST rate.",
                            "Notify your CA / tax consultant to validate the rate change applicability for your specific product codes.",
                        };
                        for (int ai = 0; ai < actions.Length; ai++)
                        {
                            <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-xl">
                                <button @@click="actionsDone[@ai] = !actionsDone[@ai]"
                                        :class="actionsDone[@ai] ? 'bg-green-500 border-green-500' : 'bg-white border-gray-300'"
                                        class="w-5 h-5 rounded border-2 flex items-center justify-center flex-shrink-0 transition-colors mt-0.5">
                                    <i x-show="actionsDone[@ai]" data-lucide="check" class="w-3 h-3 text-white"></i>
                                </button>
                                <p :class="actionsDone[@ai] ? 'line-through text-gray-400' : 'text-gray-700'"
                                   class="text-sm transition-colors">@actions[ai]</p>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-5">
            <!-- Impact -->
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
                <h3 class="font-bold text-gray-900 mb-4 flex items-center gap-2">
                    <i data-lucide="indian-rupee" class="w-5 h-5 text-green-600"></i>Financial Impact
                </h3>
                <div class="space-y-3">
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-500">Current Tax Amount</span>
                        <span class="font-semibold text-gray-900">₹50,000</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-500">New Tax Amount</span>
                        <span class="font-semibold text-red-600">₹1,20,000</span>
                    </div>
                    <div class="flex justify-between text-sm border-t pt-3">
                        <span class="text-gray-500">Additional Cost</span>
                        <span class="font-bold text-red-600">+₹70,000/year</span>
                    </div>
                </div>
                <div class="mt-4 bg-amber-50 border border-amber-200 rounded-xl p-3">
                    <p class="text-xs text-amber-700 font-semibold flex items-center gap-1.5">
                        <i data-lucide="alert-triangle" class="w-4 h-4 flex-shrink-0"></i>Penalty Info
                    </p>
                    <p class="text-xs text-amber-600 mt-1">Non-compliance penalty: 10% of tax due + 18% interest p.a. on late payment.</p>
                </div>
            </div>

            <!-- Status -->
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
                <h3 class="font-bold text-gray-900 mb-4">Status</h3>
                <div class="space-y-2">
                    @foreach (var (s, active) in new[] { ("Unread", true), ("Read", false), ("Actioned", false) })
                    {
                        <button class="flex items-center gap-2 w-full px-4 py-2.5 rounded-xl text-sm font-medium transition-colors @(active?"bg-brand-600 text-white":"bg-gray-100 text-gray-700 hover:bg-gray-200")">
                            <i data-lucide="@(s=="Unread"?"circle":s=="Read"?"eye":"check-circle")" class="w-4 h-4"></i>@s
                        </button>
                    }
                </div>
            </div>

            <!-- Related alerts -->
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
                <h3 class="font-bold text-gray-900 mb-4">Related Alerts</h3>
                <div class="space-y-3">
                    <a asp-controller="Alerts" asp-action="Detail" asp-route-id="4"
                       class="block p-3 bg-gray-50 rounded-xl hover:bg-brand-50 transition-colors">
                        <p class="text-sm font-medium text-gray-800 leading-tight hover:text-brand-600">FSSAI Labelling Rules for Packaged Food</p>
                        <p class="text-xs text-gray-400 mt-1">CBIC · 2 days ago</p>
                    </a>
                    <a asp-controller="Alerts" asp-action="Detail" asp-route-id="6"
                       class="block p-3 bg-gray-50 rounded-xl hover:bg-brand-50 transition-colors">
                        <p class="text-sm font-medium text-gray-800 leading-tight hover:text-brand-600">MCA E-Form AOC-4 Deadline Extension</p>
                        <p class="text-xs text-gray-400 mt-1">MCA · 4 days ago</p>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
