<!-- Sidebar navigation -->
<div class="flex flex-col h-full">
    <!-- Logo -->
    <div class="px-6 py-5 border-b border-white/10">
        <a asp-controller="Home" asp-action="Index" class="flex items-center gap-2">
            <div class="w-8 h-8 bg-brand-500 rounded-lg flex items-center justify-center">
                <i data-lucide="shield-check" class="w-5 h-5 text-white"></i>
            </div>
            <span class="text-white font-bold text-lg">RegWatch</span>
            <span class="text-brand-400 font-bold">India</span>
        </a>
    </div>

    <!-- Nav links -->
    <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
        <a asp-controller="Dashboard" asp-action="Index"
           class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-white/80 hover:text-white hover:bg-white/10 transition-colors group">
            <i data-lucide="layout-dashboard" class="w-5 h-5 text-white/60 group-hover:text-white"></i>
            Dashboard
        </a>
        <a asp-controller="Alerts" asp-action="Index"
           class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-white/80 hover:text-white hover:bg-white/10 transition-colors group">
            <i data-lucide="bell" class="w-5 h-5 text-white/60 group-hover:text-white"></i>
            Alerts
            <span class="ml-auto bg-danger-500 text-white text-xs font-bold px-2 py-0.5 rounded-full">3</span>
        </a>
        <a asp-controller="Regulation" asp-action="Library"
           class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-white/80 hover:text-white hover:bg-white/10 transition-colors group">
            <i data-lucide="book-open" class="w-5 h-5 text-white/60 group-hover:text-white"></i>
            Regulation Library
        </a>
        <a asp-controller="Reports" asp-action="Monthly"
           class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-white/80 hover:text-white hover:bg-white/10 transition-colors group">
            <i data-lucide="bar-chart-2" class="w-5 h-5 text-white/60 group-hover:text-white"></i>
            Reports
        </a>

        <div class="pt-4 pb-2">
            <p class="px-3 text-xs font-semibold text-white/40 uppercase tracking-wider">Settings</p>
        </div>
        <a asp-controller="Profile" asp-action="Setup"
           class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-white/80 hover:text-white hover:bg-white/10 transition-colors group">
            <i data-lucide="user" class="w-5 h-5 text-white/60 group-hover:text-white"></i>
            Profile
        </a>
        <a asp-controller="Settings" asp-action="Notifications"
           class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-white/80 hover:text-white hover:bg-white/10 transition-colors group">
            <i data-lucide="settings" class="w-5 h-5 text-white/60 group-hover:text-white"></i>
            Notifications
        </a>
        <a asp-controller="Billing" asp-action="Plans"
           class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-white/80 hover:text-white hover:bg-white/10 transition-colors group">
            <i data-lucide="credit-card" class="w-5 h-5 text-white/60 group-hover:text-white"></i>
            Billing
        </a>
    </nav>

    <!-- Upgrade CTA -->
    <div class="p-4 border-t border-white/10">
        <div class="bg-gradient-to-br from-brand-700 to-brand-900 rounded-xl p-4">
            <p class="text-white font-semibold text-sm mb-1">Free Plan</p>
            <p class="text-white/70 text-xs mb-3">You're on the Free plan. Upgrade to get unlimited alerts &amp; WhatsApp notifications.</p>
            <a asp-controller="Billing" asp-action="Plans"
               class="block text-center bg-white text-brand-700 font-semibold text-xs py-2 rounded-lg hover:bg-brand-50 transition-colors">
                Upgrade to Pro
            </a>
        </div>
        <!-- User -->
        <div class="flex items-center gap-3 mt-4">
            <div class="w-9 h-9 rounded-full bg-brand-600 flex items-center justify-center text-white font-semibold text-sm flex-shrink-0">RK</div>
            <div class="flex-1 min-w-0">
                <p class="text-white text-sm font-medium truncate">Rahul Kumar</p>
                <p class="text-white/50 text-xs truncate">rahul@acmecorp.in</p>
            </div>
            <form asp-controller="Auth" asp-action="Logout" method="post" class="flex-shrink-0">
                @Html.AntiForgeryToken()
                <button type="submit" title="Sign out"
                        class="p-1.5 text-white/50 hover:text-white transition-colors">
                    <i data-lucide="log-out" class="w-4 h-4"></i>
                </button>
            </form>
        </div>
    </div>
</div>
