@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Billing & Plans";
}
<style>[x-cloak]{display:none!important}</style>

<div class="space-y-6" x-data="{ tab: 'plan', annual: true }">
    <div class="flex items-center justify-between flex-wrap gap-3">
        <h1 class="text-2xl font-black text-gray-900">Billing &amp; Plans</h1>
        <div class="flex gap-2">
            @foreach (var t in new[] { ("plan","Current Plan"), ("invoices","Invoices"), ("payment","Payment Method") })
            {
                <button @@click="tab='@t.Item1'"
                        :class="tab==='@t.Item1' ? 'bg-brand-600 text-white' : 'bg-white text-gray-600 border border-gray-300 hover:bg-gray-50'"
                        class="px-4 py-2 text-sm font-semibold rounded-xl transition-colors">@t.Item2</button>
            }
        </div>
    </div>

    <!-- Current Plan tab -->
    <div x-show="tab==='plan'" class="space-y-5">
        <!-- Current plan banner -->
        <div class="bg-gradient-to-r from-brand-600 to-brand-800 rounded-2xl p-6 text-white">
            <div class="flex items-start justify-between flex-wrap gap-4">
                <div>
                    <div class="flex items-center gap-3 mb-2">
                        <span class="text-white/80 text-sm">Current Plan</span>
                        <span class="bg-white/20 text-white text-xs font-bold px-3 py-1 rounded-full">Free</span>
                    </div>
                    <p class="text-3xl font-black mb-1">₹0 <span class="text-white/60 text-base font-normal">/month</span></p>
                    <p class="text-white/70 text-sm">5 alerts/month · 2 regulatory bodies · Email only</p>
                </div>
                <a asp-controller="Home" asp-action="Pricing"
                   class="px-6 py-3 bg-white text-brand-700 font-bold rounded-xl hover:bg-blue-50 transition-colors flex items-center gap-2 text-sm">
                    <i data-lucide="zap" class="w-4 h-4"></i>Upgrade to Pro
                </a>
            </div>
            <div class="mt-5 bg-white/10 rounded-xl p-4">
                <div class="flex justify-between text-sm mb-2">
                    <span>Alerts used this month</span>
                    <span class="font-bold">3 / 5</span>
                </div>
                <div class="w-full bg-white/20 rounded-full h-2">
                    <div class="bg-white rounded-full h-2" style="width:60%"></div>
                </div>
            </div>
        </div>

        <!-- Plan comparison -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <div class="flex items-center justify-between mb-6 flex-wrap gap-3">
                <h2 class="font-bold text-gray-900">Upgrade Your Plan</h2>
                <div class="flex items-center gap-2">
                    <span class="text-sm text-gray-500">Monthly</span>
                    <button @@click="annual=!annual" :class="annual ? 'bg-brand-600' : 'bg-gray-300'"
                            class="relative w-10 h-5 rounded-full transition-colors">
                        <span :class="annual ? 'translate-x-5' : 'translate-x-1'"
                              class="absolute top-0.5 w-4 h-4 bg-white rounded-full transition-transform block shadow text-xs"></span>
                    </button>
                    <span class="text-sm text-gray-500">Annual <span class="text-green-600 font-bold text-xs">-20%</span></span>
                </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <!-- Pro -->
                <div class="rounded-2xl border-2 border-brand-400 p-6 relative">
                    <div class="absolute -top-3 left-5 bg-brand-600 text-white text-xs font-black px-3 py-1 rounded-full uppercase">Popular</div>
                    <h3 class="font-bold text-gray-900 text-lg mb-1">Pro</h3>
                    <p class="text-3xl font-black text-gray-900 mb-3" x-text="(annual ? '₹2,399' : '₹2,999') + ' /mo'"></p>
                    <ul class="space-y-2 text-sm mb-5">
                        @foreach (var f in new[] { "Unlimited alerts", "All 40+ bodies", "WhatsApp alerts", "Hindi summaries", "Monthly PDF reports" })
                        {<li class="flex items-center gap-2 text-gray-600"><i data-lucide="check" class="w-4 h-4 text-green-500"></i>@f</li>}
                    </ul>
                    <button class="w-full py-3 bg-brand-600 text-white font-bold rounded-xl hover:bg-brand-700 transition-colors text-sm">
                        Upgrade to Pro
                    </button>
                </div>
                <!-- Business -->
                <div class="rounded-2xl border-2 border-gray-200 p-6">
                    <h3 class="font-bold text-gray-900 text-lg mb-1">Business</h3>
                    <p class="text-3xl font-black text-gray-900 mb-3" x-text="(annual ? '₹7,199' : '₹8,999') + ' /mo'"></p>
                    <ul class="space-y-2 text-sm mb-5">
                        @foreach (var f in new[] { "Everything in Pro", "Up to 10 entities", "5 team members", "API access", "Dedicated manager" })
                        {<li class="flex items-center gap-2 text-gray-600"><i data-lucide="check" class="w-4 h-4 text-green-500"></i>@f</li>}
                    </ul>
                    <a asp-controller="Home" asp-action="Contact"
                       class="block text-center w-full py-3 bg-gray-900 text-white font-bold rounded-xl hover:bg-gray-800 transition-colors text-sm">
                        Contact Sales
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Invoices tab -->
    <div x-show="tab==='invoices'" x-cloak class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100">
            <h2 class="font-bold text-gray-900">Invoice History</h2>
        </div>
        <table class="w-full text-sm">
            <thead class="bg-gray-50">
                <tr>
                    <th class="text-left px-6 py-3 text-xs font-semibold text-gray-500">Invoice #</th>
                    <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 hidden sm:table-cell">Date</th>
                    <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500">Amount</th>
                    <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 hidden md:table-cell">Plan</th>
                    <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500">Status</th>
                    <th class="px-4 py-3"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                @{
                    var invoices = new[] {
                        ("INV-2024-003","15 Mar 2024","₹2,999","Pro Monthly","paid"),
                        ("INV-2024-002","15 Feb 2024","₹2,999","Pro Monthly","paid"),
                        ("INV-2024-001","15 Jan 2024","₹2,999","Pro Monthly","paid"),
                    };
                }
                @foreach (var (no, date, amount, plan, status) in invoices)
                {
                    <tr class="hover:bg-gray-50">
                        <td class="px-6 py-4 font-mono text-xs text-gray-700 font-semibold">@no</td>
                        <td class="px-4 py-4 text-gray-500 hidden sm:table-cell">@date</td>
                        <td class="px-4 py-4 font-semibold text-gray-900">@amount</td>
                        <td class="px-4 py-4 text-gray-500 hidden md:table-cell">@plan</td>
                        <td class="px-4 py-4">
                            <span class="bg-green-100 text-green-700 text-xs font-semibold px-2.5 py-1 rounded-full">@status</span>
                        </td>
                        <td class="px-4 py-4">
                            <a href="#" class="text-xs text-brand-600 hover:text-brand-700 font-medium flex items-center gap-1">
                                <i data-lucide="download" class="w-3.5 h-3.5"></i>PDF
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Payment Method tab -->
    <div x-show="tab==='payment'" x-cloak class="space-y-4">
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <h2 class="font-bold text-gray-900 mb-5">Payment Method</h2>
            <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-xl mb-5">
                <div class="w-12 h-8 bg-blue-600 rounded-md flex items-center justify-center">
                    <span class="text-white text-xs font-bold">VISA</span>
                </div>
                <div class="flex-1">
                    <p class="font-semibold text-gray-900 text-sm">•••• •••• •••• 4242</p>
                    <p class="text-xs text-gray-500">Expires 12/26</p>
                </div>
                <span class="text-xs bg-green-100 text-green-700 font-semibold px-2.5 py-1 rounded-full">Default</span>
            </div>
            <div class="flex gap-3">
                <button class="flex items-center gap-2 px-5 py-2.5 bg-brand-600 text-white text-sm font-semibold rounded-xl hover:bg-brand-700 transition-colors">
                    <i data-lucide="plus" class="w-4 h-4"></i>Add Card
                </button>
                <button class="flex items-center gap-2 px-5 py-2.5 bg-white border border-gray-300 text-gray-700 text-sm font-semibold rounded-xl hover:bg-gray-50 transition-colors">
                    Pay via UPI
                </button>
            </div>
        </div>
    </div>
</div>
