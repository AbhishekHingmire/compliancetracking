@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Monthly Compliance Report";
}

<div class="space-y-6">
    <!-- Header -->
    <div class="flex items-center justify-between flex-wrap gap-3">
        <div>
            <h1 class="text-2xl font-black text-gray-900">Monthly Compliance Report</h1>
            <p class="text-gray-500 text-sm mt-1">March 2024 — Acme Corp Pvt. Ltd.</p>
        </div>
        <div class="flex gap-3">
            <button class="flex items-center gap-2 px-4 py-2.5 bg-white border border-gray-300 text-sm font-medium rounded-xl hover:bg-gray-50 transition-colors">
                <i data-lucide="share-2" class="w-4 h-4 text-gray-500"></i>Share
            </button>
            <button class="flex items-center gap-2 px-4 py-2.5 bg-brand-600 text-white text-sm font-semibold rounded-xl hover:bg-brand-700 transition-colors">
                <i data-lucide="download" class="w-4 h-4"></i>Download PDF
            </button>
        </div>
    </div>

    <!-- Summary stats -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        @{
            var reportStats = new[] {
                ("bell","12","Total Alerts","bg-brand-100","text-brand-600","This month"),
                ("alert-triangle","3","High Priority","bg-red-100","text-red-600","Needs action"),
                ("check-circle","9","Actioned","bg-green-100","text-green-600","75% rate"),
                ("indian-rupee","₹2.4L","Est. Savings","bg-amber-100","text-amber-600","Identified"),
            };
        }
        @foreach (var (icon, val, label, ibg, ic, sub) in reportStats)
        {
            <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm">
                <div class="w-10 h-10 @ibg rounded-xl flex items-center justify-center mb-3">
                    <i data-lucide="@icon" class="w-5 h-5 @ic"></i>
                </div>
                <p class="text-3xl font-black text-gray-900">@val</p>
                <p class="text-sm text-gray-700 font-medium mt-0.5">@label</p>
                <p class="text-xs text-gray-400 mt-0.5">@sub</p>
            </div>
        }
    </div>

    <!-- Body breakdown + Pending actions side by side -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
        <!-- Body breakdown -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <h2 class="font-bold text-gray-900 mb-5">Alerts by Regulatory Body</h2>
            <div class="space-y-4">
                @{
                    var bodies = new[] {
                        ("CBIC","5",5,12,"text-blue-600","bg-blue-500"),
                        ("EPFO","3",3,12,"text-purple-600","bg-purple-500"),
                        ("SEBI","2",2,12,"text-green-600","bg-green-500"),
                        ("MCA","1",1,12,"text-amber-600","bg-amber-500"),
                        ("Other","1",1,12,"text-gray-600","bg-gray-400"),
                    };
                }
                @foreach (var (name, count, num, total, textCls, barCls) in bodies)
                {
                    <div>
                        <div class="flex justify-between text-sm mb-1.5">
                            <span class="font-semibold text-gray-700">@name</span>
                            <span class="@textCls font-bold">@count alerts</span>
                        </div>
                        <div class="w-full bg-gray-100 rounded-full h-2">
                            <div class="@barCls rounded-full h-2 transition-all" style="width:@(num * 100 / total)%"></div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Pending actions -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100">
                <h2 class="font-bold text-gray-900">Pending Actions</h2>
                <p class="text-xs text-gray-400 mt-0.5">Require attention before month end</p>
            </div>
            <div class="divide-y divide-gray-50">
                @{
                    var pendingActions = new[] {
                        ("GST Rate Change","CBIC","5 days","High"),
                        ("PF Threshold Update","EPFO","12 days","High"),
                        ("SEBI LODR Compliance","SEBI","15 days","Medium"),
                    };
                }
                @foreach (var (title, body, due, priority) in pendingActions)
                {
                    <div class="flex items-center gap-4 px-6 py-4">
                        <div class="w-2.5 h-2.5 rounded-full flex-shrink-0 @(priority=="High"?"bg-red-500":"bg-amber-500")"></div>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-semibold text-gray-900 truncate">@title</p>
                            <p class="text-xs text-gray-400 mt-0.5">@body · Due in @due</p>
                        </div>
                        <a asp-controller="Alerts" asp-action="Detail" asp-route-id="1"
                           class="text-xs text-brand-600 font-medium hover:text-brand-700 flex-shrink-0">View →</a>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Savings detail -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
        <h2 class="font-bold text-gray-900 mb-5">Identified Savings This Month</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            @{
                var savings = new[] {
                    ("GST Input Credit","₹85,000","CBIC circular on ITC eligibility for mixed supply"),
                    ("PF Exemption","₹36,000","Voluntary PF for employees above threshold"),
                    ("MSME Priority Credit","₹1,19,000","RBI MSME discounting scheme applies to your invoices"),
                };
            }
            @foreach (var (title, amount, note) in savings)
            {
                <div class="bg-green-50 rounded-xl p-5 border border-green-100">
                    <p class="text-sm font-semibold text-gray-900 mb-1">@title</p>
                    <p class="text-2xl font-black text-green-600 mb-2">@amount</p>
                    <p class="text-xs text-gray-500 leading-relaxed">@note</p>
                </div>
            }
        </div>
    </div>

    <!-- Print notice -->
    <div class="bg-gray-50 rounded-2xl border border-dashed border-gray-300 p-6 text-center">
        <i data-lucide="file-text" class="w-10 h-10 text-gray-300 mx-auto mb-3"></i>
        <p class="text-sm font-medium text-gray-600 mb-1">Full PDF Report Available</p>
        <p class="text-xs text-gray-400 mb-4">Includes full regulation text, action checklists, and penalty details</p>
        <button class="inline-flex items-center gap-2 px-6 py-3 bg-brand-600 text-white font-semibold rounded-xl hover:bg-brand-700 transition-colors text-sm">
            <i data-lucide="download" class="w-4 h-4"></i>Download Full Report (PDF)
        </button>
    </div>
</div>
