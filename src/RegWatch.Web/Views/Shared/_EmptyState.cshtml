@{
    string icon        = (string)(ViewData["EmptyIcon"]        ?? "inbox");
    string title       = (string)(ViewData["EmptyTitle"]       ?? "Nothing here yet");
    string description = (string)(ViewData["EmptyDescription"] ?? "");
    string actionLabel = (string)(ViewData["EmptyActionLabel"] ?? "");
    string actionUrl   = (string)(ViewData["EmptyActionUrl"]   ?? "#");
}
<div class="flex flex-col items-center justify-center py-20 text-center">
    <div class="w-16 h-16 bg-gray-100 rounded-2xl flex items-center justify-center mb-4">
        <i data-lucide="@icon" class="w-8 h-8 text-gray-400"></i>
    </div>
    <h3 class="text-lg font-semibold text-gray-900 mb-2">@title</h3>
    @if (!string.IsNullOrEmpty(description))
    {
        <p class="text-sm text-gray-500 max-w-sm">@description</p>
    }
    @if (!string.IsNullOrEmpty(actionLabel))
    {
        <a href="@actionUrl" class="mt-6 inline-flex items-center gap-2 px-5 py-2.5 bg-brand-600 text-white text-sm font-semibold rounded-xl hover:bg-brand-700 transition-colors">
            @actionLabel
        </a>
    }
</div>
