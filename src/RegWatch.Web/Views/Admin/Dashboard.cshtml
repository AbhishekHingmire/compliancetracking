@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Admin Dashboard";
}

<div class="space-y-6">
    <!-- Header -->
    <div class="flex items-center justify-between flex-wrap gap-3">
        <div>
            <h1 class="text-2xl font-black text-gray-900">Admin Dashboard</h1>
            <p class="text-gray-500 text-sm mt-1">Platform health, tenants, and scraping status</p>
        </div>
        <div class="flex items-center gap-2">
            <span class="flex items-center gap-1.5 text-xs font-semibold text-green-700 bg-green-100 px-3 py-1.5 rounded-full">
                <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>All systems operational
            </span>
        </div>
    </div>

    <!-- Platform stats -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        @{
            var adminStats = new[] {
                ("users","2,104","Total Tenants","bg-brand-100","text-brand-600","+24 this week"),
                ("zap","847","Active Today","bg-green-100","text-green-600","40% DAU"),
                ("bell","1,284","Alerts Sent","bg-purple-100","text-purple-600","Today"),
                ("clock","1.8s","Avg Scrape Time","bg-amber-100","text-amber-600","40 bodies"),
            };
        }
        @foreach (var (icon, val, label, ibg, ic, sub) in adminStats)
        {
            <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm">
                <div class="w-10 h-10 @ibg rounded-xl flex items-center justify-center mb-3">
                    <i data-lucide="@icon" class="w-5 h-5 @ic"></i>
                </div>
                <p class="text-3xl font-black text-gray-900">@val</p>
                <p class="text-sm text-gray-700 font-medium mt-0.5">@label</p>
                <p class="text-xs text-gray-400 mt-0.5">@sub</p>
            </div>
        }
    </div>

    <!-- Scraping status + recent tenants -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
        <!-- Scrape logs -->
        <div class="lg:col-span-2 bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
            <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
                <h2 class="font-bold text-gray-900">Scraping Status</h2>
                <span class="text-xs text-gray-400">Last 24 hours</span>
            </div>
            <table class="w-full text-sm">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="text-left px-6 py-3 text-xs font-semibold text-gray-500">Body</th>
                        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 hidden sm:table-cell">Status</th>
                        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 hidden md:table-cell">New Items</th>
                        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 hidden lg:table-cell">Duration</th>
                        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500">Last Run</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @{
                        var scrapeLogs = new[] {
                            ("CBIC","success",5,"1.2s","2 min ago"),
                            ("SEBI","success",2,"2.1s","5 min ago"),
                            ("EPFO","success",1,"0.9s","8 min ago"),
                            ("MCA","error",0,"—","15 min ago"),
                            ("FSSAI","success",3,"1.8s","20 min ago"),
                            ("RBI","success",0,"1.1s","22 min ago"),
                        };
                    }
                    @foreach (var (body, status, items, dur, last) in scrapeLogs)
                    {
                        <tr class="hover:bg-gray-50">
                            <td class="px-6 py-3.5 font-semibold text-gray-900">@body</td>
                            <td class="px-4 py-3.5 hidden sm:table-cell">
                                <span class="text-xs font-semibold px-2 py-0.5 rounded-full @(status=="success"?"bg-green-100 text-green-700":"bg-red-100 text-red-700")">@status</span>
                            </td>
                            <td class="px-4 py-3.5 text-gray-700 hidden md:table-cell">@items</td>
                            <td class="px-4 py-3.5 text-gray-400 hidden lg:table-cell">@dur</td>
                            <td class="px-4 py-3.5 text-gray-400 text-xs">@last</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Recent tenants -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
            <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
                <h2 class="font-bold text-gray-900">New Tenants</h2>
                <span class="text-xs text-gray-400">This week</span>
            </div>
            <div class="divide-y divide-gray-50">
                @{
                    var tenants = new[] {
                        ("AC","Acme Corp","Free","Maharashtra","1h ago"),
                        ("GL","GreenLeaf Foods","Pro","Karnataka","3h ago"),
                        ("NF","NexaFin Capital","Business","Delhi","5h ago"),
                        ("TW","TextileWorks","Pro","Gujarat","1d ago"),
                        ("BS","BlueStar IT","Free","Pune","2d ago"),
                    };
                }
                @foreach (var (initials, name, plan, state, when) in tenants)
                {
                    <div class="flex items-center gap-3 px-6 py-3.5">
                        <div class="w-9 h-9 rounded-xl bg-brand-600 flex items-center justify-center text-white font-bold text-xs flex-shrink-0">@initials</div>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-semibold text-gray-900 truncate">@name</p>
                            <p class="text-xs text-gray-400">@state · @when</p>
                        </div>
                        <span class="text-xs font-semibold px-2 py-0.5 rounded-full @(plan=="Pro"?"bg-brand-100 text-brand-700":plan=="Business"?"bg-purple-100 text-purple-700":"bg-gray-100 text-gray-600")">@plan</span>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Quick actions -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
        <h2 class="font-bold text-gray-900 mb-4">Quick Actions</h2>
        <div class="flex flex-wrap gap-3">
            <button class="flex items-center gap-2 px-4 py-2.5 bg-brand-600 text-white text-sm font-semibold rounded-xl hover:bg-brand-700 transition-colors">
                <i data-lucide="refresh-cw" class="w-4 h-4"></i>Trigger Manual Scrape
            </button>
            <button class="flex items-center gap-2 px-4 py-2.5 bg-white border border-gray-300 text-gray-700 text-sm font-medium rounded-xl hover:bg-gray-50 transition-colors">
                <i data-lucide="send" class="w-4 h-4"></i>Send Test Alert
            </button>
            <button class="flex items-center gap-2 px-4 py-2.5 bg-white border border-gray-300 text-gray-700 text-sm font-medium rounded-xl hover:bg-gray-50 transition-colors">
                <i data-lucide="database" class="w-4 h-4"></i>View DB Stats
            </button>
            <button class="flex items-center gap-2 px-4 py-2.5 bg-white border border-gray-300 text-gray-700 text-sm font-medium rounded-xl hover:bg-gray-50 transition-colors">
                <i data-lucide="file-text" class="w-4 h-4"></i>View Logs
            </button>
        </div>
    </div>
</div>
