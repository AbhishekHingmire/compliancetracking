<footer class="bg-gray-950 text-gray-400">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-8 lg:gap-12">
            <!-- Brand -->
            <div class="lg:col-span-2">
                <a asp-controller="Home" asp-action="Index" class="flex items-center gap-2 mb-4">
                    <div class="w-8 h-8 bg-brand-600 rounded-lg flex items-center justify-center">
                        <i data-lucide="shield-check" class="w-5 h-5 text-white"></i>
                    </div>
                    <span class="text-white font-bold text-lg">RegWatch</span>
                    <span class="text-brand-400 font-bold text-lg">India</span>
                </a>
                <p class="text-sm leading-relaxed mb-6">
                    India's most intelligent regulatory compliance platform. Monitor 40+ regulatory bodies and never miss a deadline that could cost your business.
                </p>
                <div class="flex gap-3">
                    <a href="#" class="w-9 h-9 bg-gray-800 hover:bg-brand-600 rounded-lg flex items-center justify-center transition-colors">
                        <i data-lucide="twitter" class="w-4 h-4 text-gray-400"></i>
                    </a>
                    <a href="#" class="w-9 h-9 bg-gray-800 hover:bg-brand-600 rounded-lg flex items-center justify-center transition-colors">
                        <i data-lucide="linkedin" class="w-4 h-4 text-gray-400"></i>
                    </a>
                    <a href="#" class="w-9 h-9 bg-gray-800 hover:bg-brand-600 rounded-lg flex items-center justify-center transition-colors">
                        <i data-lucide="youtube" class="w-4 h-4 text-gray-400"></i>
                    </a>
                </div>
            </div>

            <!-- Product -->
            <div>
                <h4 class="text-white font-semibold mb-4">Product</h4>
                <ul class="space-y-2 text-sm">
                    <li><a asp-controller="Dashboard" asp-action="Index" class="hover:text-white transition-colors">Dashboard</a></li>
                    <li><a asp-controller="Alerts" asp-action="Index" class="hover:text-white transition-colors">Alerts</a></li>
                    <li><a asp-controller="Regulation" asp-action="Library" class="hover:text-white transition-colors">Regulation Library</a></li>
                    <li><a asp-controller="Reports" asp-action="Monthly" class="hover:text-white transition-colors">Reports</a></li>
                    <li><a asp-controller="Home" asp-action="Pricing" class="hover:text-white transition-colors">Pricing</a></li>
                </ul>
            </div>

            <!-- Company -->
            <div>
                <h4 class="text-white font-semibold mb-4">Company</h4>
                <ul class="space-y-2 text-sm">
                    <li><a asp-controller="Home" asp-action="About" class="hover:text-white transition-colors">About Us</a></li>
                    <li><a asp-controller="Home" asp-action="Contact" class="hover:text-white transition-colors">Contact</a></li>
                    <li><a href="#" class="hover:text-white transition-colors">Blog</a></li>
                    <li><a href="#" class="hover:text-white transition-colors">Careers</a></li>
                    <li><a href="#" class="hover:text-white transition-colors">Press</a></li>
                </ul>
            </div>

            <!-- Legal -->
            <div>
                <h4 class="text-white font-semibold mb-4">Legal</h4>
                <ul class="space-y-2 text-sm">
                    <li><a href="#" class="hover:text-white transition-colors">Privacy Policy</a></li>
                    <li><a href="#" class="hover:text-white transition-colors">Terms of Service</a></li>
                    <li><a href="#" class="hover:text-white transition-colors">Cookie Policy</a></li>
                    <li><a href="#" class="hover:text-white transition-colors">GDPR / DPDP</a></li>
                    <li><a href="#" class="hover:text-white transition-colors">Refund Policy</a></li>
                </ul>
            </div>
        </div>

        <div class="mt-12 pt-8 border-t border-gray-800 flex flex-col sm:flex-row items-center justify-between gap-4">
            <p class="text-sm">&copy; @DateTime.Now.Year RegWatch India Pvt. Ltd. All rights reserved.</p>
            <p class="text-sm flex items-center gap-1">
                Made with <i data-lucide="heart" class="w-4 h-4 text-red-500 fill-current"></i> in India
            </p>
        </div>
    </div>
</footer>
